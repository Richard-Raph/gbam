{
  "name": "gbam",
  "displayName": "Gbam",
  "description": "Satisfying Gbam sound when your code succeeds",
  "version": "0.0.1",
  "publisher": "RichardRapahel",
  "license": "SEE LICENSE IN <filename>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Richard-Raph/gbam"
  },
  "bugs": {
    "url": "https://github.com/Richard-Raph/gbam/issues"
  },
  "homepage": "https://github.com/Richard-Raph/gbam#readme",
  "icon": "media/gbam.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "nigeria",
    "success",
    "africa",
    "sound",
    "build",
    "gbam",
    "test",
    "meme"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "files": [
    "out",
    "media"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gbam.enable",
        "title": "Enable Gbam",
        "category": "Gbam"
      },
      {
        "command": "gbam.disable",
        "title": "Disable Gbam",
        "category": "Gbam"
      },
      {
        "command": "gbam.test",
        "title": "Test Gbam Sound",
        "category": "Gbam"
      }
    ],
    "configuration": {
      "title": "Gbam",
      "properties": {
        "gbam.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Play Gbam when success is detected"
        },
        "gbam.volume": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Sound volume (0-1)"
        },
        "gbam.triggerOn": {
          "type": "array",
          "default": [
            "test",
            "debug"
          ],
          "description": "Events that trigger Gbam"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
