{
  "name": "gbam",
  "displayName": "Gbam",
  "description": "Satisfying Gbam sound when your code succeeds",
  "version": "0.0.1",
  "publisher": "RichardRapahel",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/Richard-Raph/gbam"
  },
  "bugs": {
    "url": "https://github.com/Richard-Raph/gbam/issues"
  },
  "homepage": "https://github.com/Richard-Raph/gbam#readme",
  "icon": "media/gbam.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "keywords": [
    "nigeria",
    "success",
    "africa",
    "sound",
    "build",
    "gbam",
    "test",
    "meme"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "files": [
    "out",
    "media",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gbam.enable",
        "title": "Enable Gbam",
        "category": "Gbam"
      },
      {
        "command": "gbam.disable",
        "title": "Disable Gbam",
        "category": "Gbam"
      },
      {
        "command": "gbam.test",
        "title": "Test Gbam Sound",
        "category": "Gbam"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.9.3"
  }
}